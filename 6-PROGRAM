#include <stdio.h>
#include <string.h>
#include <ctype.h>

int main()
{
    char cipher[100];
    int i;

    int a = 3;
    int b = 15;

    // Multiplicative inverse of 3 modulo 26
    int a_inv = 9;

    printf("Enter Ciphertext (uppercase): ");
    scanf("%s", cipher);

    printf("Plaintext: ");

    for(i = 0; cipher[i] != '\0'; i++)
    {
        if(isupper(cipher[i]))
        {
            int c = cipher[i] - 'A';
            int p = (a_inv * (c - b + 26)) % 26;
            printf("%c", p + 'A');
        }
    }

    return 0;
}