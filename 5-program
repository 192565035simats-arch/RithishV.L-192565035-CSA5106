#include <stdio.h>
#include <string.h>
#include <ctype.h>

int gcd(int a, int b)
{
    while(b != 0)
    {
        int temp = b;
        b = a % b;
        a = temp;
    }
    return a;
}

int main()
{
    char text[100];
    int a, b, i;

    printf("Enter plaintext (uppercase): ");
    scanf("%s", text);

    printf("Enter value of a: ");
    scanf("%d", &a);

    printf("Enter value of b: ");
    scanf("%d", &b);

    if(gcd(a,26) != 1)
    {
        printf("Invalid value of a.\n");
        printf("a must be coprime with 26.\n");
        return 0;
    }

    printf("Ciphertext: ");

    for(i = 0; text[i] != '\0'; i++)
    {
        if(isupper(text[i]))
        {
            int p = text[i] - 'A';
            int c = (a * p + b) % 26;
            printf("%c", c + 'A');
        }
    }

    return 0;
}