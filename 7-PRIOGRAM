#include <stdio.h>
#include <string.h>

char decrypt(char ch)
{
    switch(ch)
    {
        case '5': return 'A';
        case '3': return 'G';
        /* replaced non-ASCII symbols with ASCII placeholders */
        case 'X': return 'D'; /* was '‡' */
        case 'Y': return 'L'; /* was '†' */
        case '0': return 'F';
        case ')': return 'N';
        case '6': return 'I';
        case '*': return 'S';
        case ';': return 'T';
        case '4': return 'H';
        case '8': return 'E';
        case '2': return 'R';
        case 'Z': return 'V'; /* was '¶' */
        case ']': return 'B';
        case ':': return 'P';
        case '?': return 'U';
        case '(': return 'O';
        case '9': return 'M';
        case '1': return 'Y';
        case '.': return '\'';
        case '-': return 'W';
        default:  return ch;
    }
}

