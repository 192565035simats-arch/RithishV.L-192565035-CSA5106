#include <stdio.h>
#include <string.h>
#include <ctype.h>

char keyMatrix[5][5] = {
    {'P','L','A','Y','F'},
    {'I','R','E','X','M'},
    {'B','C','D','G','H'},
    {'K','N','O','Q','S'},
    {'T','U','V','W','Z'}
};

void findPosition(char ch, int *row, int *col)
{
    if(ch == 'J')
        ch = 'I';

    for(int i = 0; i < 5; i++)
    {
        for(int j = 0; j < 5; j++)
        {
            if(keyMatrix[i][j] == ch)
            {
                *row = i;
                *col = j;
                return;
            }
        }
    }
}

void decryptPair(char a, char b)
{
    int r1, c1, r2, c2;

    findPosition(a, &r1, &c1);
    findPosition(b, &r2, &c2);

    if(r1 == r2)
    {
        printf("%c%c",
               keyMatrix[r1][(c1 + 4) % 5],
               keyMatrix[r2][(c2 + 4) % 5]);
    }
    else if(c1 == c2)
    {
        printf("%c%c",
               keyMatrix[(r1 + 4) % 5][c1],
               keyMatrix[(r2 + 4) % 5][c2]);
    }
    else
    {
        printf("%c%c",
               keyMatrix[r1][c2],
               keyMatrix[r2][c1]);
    }
}

int main()
{
    char cipher[] =
    "KXJEYUREBEZWEHEWRYTUHEYFS"
    "KREHEGOYFIWTTTUOLKSYCAJPO"
    "BOTEIZONTXBYBNTGONEYCUZWR"
    "GDSONSXBOUYWRHEBAAHYUSEDQ";

    int len = strlen(cipher);

    printf("Cipher Text:\n%s\n\n", cipher);

    printf("Plain Text:\n");

    for(int i = 0; i < len; i += 2)
    {
        decryptPair(cipher[i], cipher[i + 1]);
    }

    printf("\n");

    return 0;
}
